# ==============================================
# AgriConnect Backend Environment Variables
# ==============================================

# Server Configuration
PORT=5000
NODE_ENV=development

# ==============================================
# Database Configuration (PostgreSQL)
# ==============================================
# For local development, use localhost
# For Render deployment, use the database connection details from Render dashboard
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agriconnect
DB_USER=postgres
DB_PASSWORD=postgres

# ==============================================
# JWT Authentication
# ==============================================
# IMPORTANT: Generate a strong random secret for production
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=24h

# ==============================================
# Weather API (OpenWeatherMap)
# ==============================================
# Get your free API key from: https://openweathermap.org/api
WEATHER_API_KEY=your-weather-api-key
WEATHER_API_URL=https://api.openweathermap.org/data/2.5

# ==============================================
# SMS Gateway (Twilio)
# ==============================================
# Get credentials from: https://console.twilio.com/
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number

# ==============================================
# CORS Configuration
# ==============================================
# For local development: http://localhost:3000
# For production: your frontend URL (e.g., https://agri-connect.onrender.com)
CORS_ORIGIN=http://localhost:3000

# ==============================================
# Email Configuration (Gmail SMTP)
# ==============================================
# For Gmail, generate an App Password from:
# Google Account → Security → 2-Step Verification → App passwords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password
EMAIL_FROM=AgriConnect <your-email@gmail.com>

# Frontend URL (for password reset links)
# For local development: http://localhost:3000
# For production: your frontend URL (e.g., https://agri-connect.onrender.com)
FRONTEND_URL=http://localhost:3000
